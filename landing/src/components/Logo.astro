---
/**
 * App icon Peliculle — les trois « pellicules » empilées (ambre / bleu / vert)
 * en liquid glass, avec le viseur au centre. Usage visuel : hero, footer,
 * favicon (voir /public/logo.svg). Le coin arrondi façon squircle iOS est
 * appliqué en CSS, la source restant carrée pleine page.
 */
interface Props {
  class?: string;
  size?: number;
  /** Vide quand un wordmark « Peliculle » lisible est déjà juste à côté. */
  alt?: string;
  /** Attributs restants (ex. data-hero-item pour l'anim GSAP) forwardés au <img>. */
  [key: string]: unknown;
}
const { class: className = '', size = 48, alt = 'Peliculle', ...rest } = Astro.props;
---

<img
  class:list={['logo', className]}
  src="/logo.svg"
  width={size}
  height={size}
  alt={alt}
  decoding="async"
  {...rest}
/>

<style>
  .logo {
    display: block;
    border-radius: 22.5%;
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.06),
      var(--shadow-lift, 0 8px 24px rgba(0, 0, 0, 0.12));
  }
</style>
