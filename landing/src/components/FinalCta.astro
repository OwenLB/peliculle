---
import WaitlistForm from './WaitlistForm.astro';
import AppStoreBadge from './AppStoreBadge.astro';
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

// La pellicule « après tri » : cinq gardées, la couleur vient d'elles.
const keepers = [
  '/images/swipe/field-sunset.webp',
  '/images/swipe/sea-boat.webp',
  '/images/swipe/snow-peaks.webp',
  '/images/swipe/waterfall.webp',
  '/images/swipe/purple-flower.webp',
];
---

<section class="section section--ink cta">
  <div class="cta-glow" aria-hidden="true"></div>
  <div class="container container--narrow cta-inner">
    <figure class="cta-strip" data-reveal>
      <div class="cta-strip-row" aria-hidden="true">
        {
          keepers.map((src, index) => (
            <span class="cta-keeper" style={`--i: ${index}`}>
              <img src={src} width="120" height="160" alt="" loading="lazy" decoding="async" />
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="m5 12.5 4.5 4.5L19 7.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          ))
        }
      </div>
      <figcaption>{t('cta.strip')}</figcaption>
    </figure>

    <h2 class="cta-title" data-reveal>
      {t('cta.title')}<br />
      <span class="accent">{t('cta.title.accent')}</span>
    </h2>
    <p class="section-lede" data-reveal>{t('cta.subtitle')}</p>
    <div class="cta-actions" data-reveal>
      <WaitlistForm lang={lang} />
      <AppStoreBadge lang={lang} />
    </div>
  </div>
</section>

<style>
  .cta {
    overflow: clip;
  }

  .cta-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(48rem 26rem at 50% 115%, var(--ambient), transparent 65%);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.6rem;
  }

  .cta-strip {
    display: grid;
    justify-items: center;
    gap: 0.9rem;
    margin-bottom: 1.6rem;
  }

  .cta-strip-row {
    display: flex;
  }

  .cta-keeper {
    position: relative;
    rotate: calc((var(--i) - 2) * 3.5deg);
    translate: 0 calc((var(--i) - 2) * (var(--i) - 2) * 0.14rem);
    margin-inline: -0.3rem;
    transition: translate 0.35s var(--ease-out), rotate 0.35s var(--ease-out);
  }

  .cta-keeper:hover {
    translate: 0 -0.5rem;
    rotate: 0deg;
    z-index: 1;
  }

  .cta-keeper img {
    width: clamp(3.4rem, 3rem + 3vw, 5rem);
    height: auto;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.55);
  }

  .cta-keeper svg {
    position: absolute;
    right: -0.3rem;
    bottom: -0.3rem;
    width: 1.15rem;
    height: 1.15rem;
    padding: 0.2rem;
    border-radius: 999px;
    background: rgba(48, 209, 88, 0.92);
    color: #04120a;
  }

  .cta-strip figcaption {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .cta-title {
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.08;
    text-wrap: balance;
  }

  .cta-actions {
    margin-top: 1.8rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
    width: 100%;
  }

  /* Le formulaire sur fond encre */
  .cta :global(.waitlist) {
    margin-inline: auto;
  }

  .cta :global(.waitlist-note) {
    color: var(--ink-paper-soft);
    text-align: center;
    padding-left: 0;
  }

  .cta :global(.appstore-badge) {
    background: var(--glass-strong);
    box-shadow: inset 0 0 0 1px var(--ink-line);
  }
</style>
