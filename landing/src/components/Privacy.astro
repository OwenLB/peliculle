---
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const icons = [
  '<rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/><circle cx="12" cy="15.5" r="1.5"/>',
  '<rect x="7" y="2.5" width="10" height="19" rx="2.5"/><path d="M11 18.5h2"/>',
  '<circle cx="12" cy="12" r="8.5"/><path d="M12 7.5V12l3 2"/>',
  '<path d="M9 14 4 9l5-5"/><path d="M4 9h10a6 6 0 0 1 0 12h-3"/>',
];

const items = [1, 2, 3, 4].map((i, index) => ({
  icon: icons[index],
  title: t(`privacy.${i}.title`),
  text: t(`privacy.${i}.text`),
}));
---

<section class="section section--ink" id="privacy">
  <div class="container">
    <p class="eyebrow" data-reveal>( )</p>
    <h2 class="section-title" data-reveal>{t('privacy.title')}</h2>
    <p class="section-lede" data-reveal>{t('privacy.subtitle')}</p>

    <div class="privacy-grid" data-reveal-group>
      {
        items.map((item) => (
          <article class="privacy-card">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={item.icon}
            />
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .privacy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 1.1rem;
    margin-top: 3rem;
  }

  .privacy-card {
    background: var(--ink-bg-raised);
    border: 1px solid var(--ink-line);
    border-radius: var(--radius-lg);
    padding: 1.7rem;
  }

  .privacy-card svg {
    width: 2rem;
    height: 2rem;
    color: var(--amber);
    margin-bottom: 1.1rem;
  }

  .privacy-card h3 {
    font-size: var(--text-base);
    font-weight: 650;
    margin-bottom: 0.35rem;
  }

  .privacy-card p {
    font-size: var(--text-sm);
    color: var(--ink-paper-soft);
  }

  #privacy .eyebrow {
    color: var(--amber);
  }
</style>
