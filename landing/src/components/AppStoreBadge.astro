 * Badge « Bientôt sur l'App Store » — placeholder non cliquable.
 * Au lancement : remplacer par le badge officiel Apple + lien App Store.
 */
import { useTranslations, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
